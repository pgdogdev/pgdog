{
  "title": "PgDog",
  "description": "PgDog is a connection pooler, load balancer and database sharder.",
  "widgets": [
    {
      "id": 8188370737217765,
      "definition": {
        "title": "Connection pooler",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 2621949102613607,
            "definition": {
              "title": "Connection pool utilization",
              "title_size": "16",
              "title_align": "left",
              "description": "Connection pool utilization as a percentage of the total available connections.",
              "type": "query_value",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "query2",
                      "data_source": "metrics",
                      "query": "avg:pgdog.sv_active{*}",
                      "aggregator": "sum"
                    },
                    {
                      "name": "query1",
                      "data_source": "metrics",
                      "query": "avg:pgdog.max_connections{*}",
                      "aggregator": "sum"
                    }
                  ],
                  "formulas": [
                    {
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "percent"
                        }
                      },
                      "formula": "query2 / query1 * 100"
                    }
                  ],
                  "conditional_formats": [
                    {
                      "comparator": ">",
                      "value": 50,
                      "palette": "yellow_on_white"
                    }
                  ]
                }
              ],
              "autoscale": true,
              "precision": 2,
              "timeseries_background": { "type": "area" }
            },
            "layout": { "x": 0, "y": 0, "width": 4, "height": 2 }
          },
          {
            "id": 3208416645349346,
            "definition": {
              "title": "Client maxwait",
              "title_size": "16",
              "title_align": "left",
              "description": "How long clients had to wait (in the worst case) to receive a connection from the pool. A high value indicates pool overutilization.",
              "type": "query_value",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "query1",
                      "data_source": "metrics",
                      "query": "avg:pgdog.maxwait{*}",
                      "aggregator": "max"
                    }
                  ],
                  "conditional_formats": [
                    {
                      "comparator": ">",
                      "value": 10,
                      "palette": "white_on_yellow"
                    }
                  ],
                  "formulas": [{ "formula": "query1 * 1000" }]
                }
              ],
              "autoscale": true,
              "precision": 2,
              "timeseries_background": { "type": "area" }
            },
            "layout": { "x": 4, "y": 0, "width": 4, "height": 2 }
          },
          {
            "id": 8479117972864197,
            "definition": {
              "title": "QPS",
              "title_size": "16",
              "title_align": "left",
              "description": "Queries per second, the universal metric of database throughput.",
              "type": "query_value",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "query1",
                      "data_source": "metrics",
                      "query": "sum:pgdog.total_query_count{*}.as_rate()",
                      "aggregator": "max"
                    }
                  ],
                  "formulas": [{ "formula": "query1" }]
                }
              ],
              "autoscale": true,
              "precision": 2,
              "timeseries_background": { "type": "bars" }
            },
            "layout": { "x": 8, "y": 0, "width": 4, "height": 2 }
          },
          {
            "id": 6307488900350408,
            "definition": {
              "title": "Server connections",
              "title_size": "16",
              "title_align": "left",
              "description": "Total number of connections from PgDog to PostgreSQL.",
              "show_legend": true,
              "legend_layout": "auto",
              "legend_columns": ["avg", "min", "max", "value", "sum"],
              "type": "timeseries",
              "requests": [
                {
                  "response_format": "timeseries",
                  "queries": [
                    {
                      "name": "query1",
                      "data_source": "metrics",
                      "query": "max:pgdog.sv_idle{*} by {service,database,host}"
                    },
                    {
                      "name": "query2",
                      "data_source": "metrics",
                      "query": "max:pgdog.sv_active{*} by {service,database,host}"
                    }
                  ],
                  "formulas": [
                    {
                      "alias": "sv_idle + sv_active + sv_idle_xact",
                      "formula": "query1 + query2"
                    }
                  ],
                  "style": {
                    "palette": "dog_classic",
                    "order_by": "values",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "display_type": "bars"
                },
                {
                  "response_format": "timeseries",
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query0",
                      "query": "sum:pgdog.max_connections{*} by {host,database,service}"
                    }
                  ],
                  "formulas": [
                    { "alias": "max_connections", "formula": "query0" }
                  ],
                  "style": {
                    "palette": "red",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "display_type": "line"
                }
              ]
            },
            "layout": { "x": 0, "y": 2, "width": 4, "height": 3 }
          },
          {
            "id": 8134735596910621,
            "definition": {
