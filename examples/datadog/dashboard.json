            "definition": {
              "title": "Query parser overhead",
              "title_size": "16",
              "title_align": "left",
              "description": "Stacked bar chart showing parse time vs execution time per query, grouped by service.",
              "show_legend": true,
              "legend_layout": "auto",
              "legend_columns": ["avg", "min", "max", "value", "sum"],
              "type": "timeseries",
              "requests": [
                {
                  "response_format": "timeseries",
                  "queries": [
                    {
                      "name": "total_time",
                      "data_source": "metrics",
                      "query": "sum:pgdog.total_query_time{*} by {service}.as_count()"
                    },
                    {
                      "name": "parse_time",
                      "data_source": "metrics",
                      "query": "sum:pgdog.query_cache_parse_time{*} by {service}.as_count()"
                    },
                    {
                      "name": "query_count",
                      "data_source": "metrics",
                      "query": "sum:pgdog.total_query_count{*} by {service}.as_count()"
                    }
                  ],
                  "formulas": [
                    {
                      "alias": "Execution time per query",
                      "formula": "(total_time - parse_time) / query_count"
                    },
                    {
                      "alias": "Parse time per query",
                      "style": { "palette": "red" },
                      "formula": "parse_time / query_count"
                    }
                  ],
                  "style": {
                    "palette": "dog_classic",
                    "order_by": "values",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "display_type": "bars"
